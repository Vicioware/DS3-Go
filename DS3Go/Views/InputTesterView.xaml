<UserControl x:Class="DS3Go.Views.InputTesterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DS3Go.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <!-- No controller message -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <TextBlock Text="🎮" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Ningún mando conectado en este puerto"
                       FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Controller visualization -->
        <Viewbox Stretch="Uniform" MaxHeight="480"
                 Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
            <Canvas Width="860" Height="440" ClipToBounds="False">

                <!-- ═══ Controller body silhouette ═══ -->
                <Path Canvas.Left="80" Canvas.Top="60" Fill="#13131C" Stroke="{StaticResource BorderBrush}" StrokeThickness="1.5"
                      Data="M 130,0 L 570,0 C 620,0 660,30 680,80 L 700,180 C 700,240 660,280 620,300 L 580,330 C 540,355 500,370 430,370 L 270,370 C 200,370 160,355 120,330 L 80,300 C 40,280 0,240 0,180 L 20,80 C 40,30 80,0 130,0 Z"/>

                <!-- ═══ TRIGGERS (top) ═══ -->

                <!-- L2 -->
                <Border Canvas.Left="130" Canvas.Top="30" Width="22" Height="80"
                        CornerRadius="5" Background="{StaticResource StickBgBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        ClipToBounds="True">
                    <Grid VerticalAlignment="Bottom">
                        <Rectangle Width="20" Height="{Binding L2BarHeight, FallbackValue=0}"
                                   RadiusX="4" RadiusY="4" Fill="{StaticResource TriggerLBrush}"/>
                    </Grid>
                </Border>
                <TextBlock Canvas.Left="126" Canvas.Top="112" Width="30" TextAlignment="Center"
                           Text="L2" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>

                <!-- R2 -->
                <Border Canvas.Left="708" Canvas.Top="30" Width="22" Height="80"
                        CornerRadius="5" Background="{StaticResource StickBgBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        ClipToBounds="True">
                    <Grid VerticalAlignment="Bottom">
                        <Rectangle Width="20" Height="{Binding R2BarHeight, FallbackValue=0}"
                                   RadiusX="4" RadiusY="4" Fill="{StaticResource TriggerRBrush}"/>
                    </Grid>
                </Border>
                <TextBlock Canvas.Left="704" Canvas.Top="112" Width="30" TextAlignment="Center"
                           Text="R2" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>

                <!-- ═══ BUMPERS ═══ -->

                <!-- L1 -->
                <Border Canvas.Left="168" Canvas.Top="72" Width="80" Height="24" CornerRadius="6"
                        BorderThickness="1.5">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BtnOffBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BumperLBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding L1Pressed}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BumperLBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="L1" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="11" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                </Border>

                <!-- R1 -->
                <Border Canvas.Left="612" Canvas.Top="72" Width="80" Height="24" CornerRadius="6"
                        BorderThickness="1.5">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BtnOffBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BumperRBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding R1Pressed}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BumperRBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="R1" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="11" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                </Border>

                <!-- ═══ D-PAD (left side, below L-stick level on a DS3) ═══ -->

                <!-- D-Pad Center -->
                <Rectangle Canvas.Left="194" Canvas.Top="225" Width="24" Height="24" RadiusX="3" RadiusY="3"
                           Fill="{StaticResource BtnOffBrush}"/>
                <!-- Up -->
                <Rectangle Canvas.Left="194" Canvas.Top="199" Width="24" Height="24" RadiusX="3" RadiusY="3">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Setter Property="Fill" Value="{StaticResource BtnOffBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DpadUpPressed}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource DPadOnBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>
                <!-- Down -->
                <Rectangle Canvas.Left="194" Canvas.Top="251" Width="24" Height="24" RadiusX="3" RadiusY="3">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Setter Property="Fill" Value="{StaticResource BtnOffBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DpadDownPressed}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource DPadOnBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>
                <!-- Left -->
                <Rectangle Canvas.Left="168" Canvas.Top="225" Width="24" Height="24" RadiusX="3" RadiusY="3">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Setter Property="Fill" Value="{StaticResource BtnOffBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DpadLeftPressed}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource DPadOnBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>
                <!-- Right -->
                <Rectangle Canvas.Left="220" Canvas.Top="225" Width="24" Height="24" RadiusX="3" RadiusY="3">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Setter Property="Fill" Value="{StaticResource BtnOffBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DpadRightPressed}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource DPadOnBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>

                <!-- ═══ LEFT STICK (lower-left, PS3 symmetric position) ═══ -->
                <Ellipse Canvas.Left="260" Canvas.Top="300" Width="120" Height="120"
                         Fill="{StaticResource StickBgBrush}" Stroke="{StaticResource StickRingBrush}" StrokeThickness="1.5"/>
                <!-- Crosshair lines -->
                <Line X1="260" Y1="360" X2="380" Y2="360" Stroke="#1A1A28" StrokeThickness="1"/>
                <Line X1="320" Y1="300" X2="320" Y2="420" Stroke="#1A1A28" StrokeThickness="1"/>
                <!-- Dot -->
                <Ellipse Width="20" Height="20" Canvas.Left="310" Canvas.Top="350">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource StickDotBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding L3Pressed}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource BtnCircleBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                    <Ellipse.RenderTransform>
                        <TranslateTransform X="{Binding LeftStickOffsetX}" Y="{Binding LeftStickOffsetY}"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <TextBlock Canvas.Left="295" Canvas.Top="424" Width="50" TextAlignment="Center"
                           Text="{Binding LeftStickCoords}" FontSize="9"
                           Foreground="{StaticResource TextSecondaryBrush}"/>

                <!-- ═══ RIGHT STICK (lower-right, PS3 symmetric position) ═══ -->
                <Ellipse Canvas.Left="480" Canvas.Top="300" Width="120" Height="120"
                         Fill="{StaticResource StickBgBrush}" Stroke="{StaticResource StickRingBrush}" StrokeThickness="1.5"/>
                <Line X1="480" Y1="360" X2="600" Y2="360" Stroke="#1A1A28" StrokeThickness="1"/>
                <Line X1="540" Y1="300" X2="540" Y2="420" Stroke="#1A1A28" StrokeThickness="1"/>
                <Ellipse Width="20" Height="20" Canvas.Left="530" Canvas.Top="350">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource StickDotBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding R3Pressed}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource BtnCircleBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                    <Ellipse.RenderTransform>
                        <TranslateTransform X="{Binding RightStickOffsetX}" Y="{Binding RightStickOffsetY}"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <TextBlock Canvas.Left="515" Canvas.Top="424" Width="50" TextAlignment="Center"
                           Text="{Binding RightStickCoords}" FontSize="9"
                           Foreground="{StaticResource TextSecondaryBrush}"/>

                <!-- ═══ CENTER BUTTONS (Select, PS, Start) ═══ -->

                <!-- SELECT -->
                <Border Canvas.Left="355" Canvas.Top="160" Width="44" Height="20" CornerRadius="10"
                        BorderThickness="1.5">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BtnOffBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectPressed}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="SEL" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="9" FontWeight="Medium">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectPressed}" Value="True">
                                        <Setter Property="Foreground" Value="#0E0E14"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <!-- PS -->
                <Ellipse Canvas.Left="416" Canvas.Top="190" Width="28" Height="28" StrokeThickness="1.5">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource BtnOffBrush}"/>
                            <Setter Property="Stroke" Value="{StaticResource BorderBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PsPressed}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="Stroke" Value="{StaticResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Canvas.Left="416" Canvas.Top="220" Width="28"
                           Text="PS" FontSize="9" TextAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>

                <!-- START -->
                <Border Canvas.Left="461" Canvas.Top="160" Width="44" Height="20" CornerRadius="10"
                        BorderThickness="1.5">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BtnOffBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StartPressed}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource TextPrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="STA" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="9" FontWeight="Medium">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StartPressed}" Value="True">
                                        <Setter Property="Foreground" Value="#0E0E14"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <!-- ═══ ACTION BUTTONS (right side, PS3 diamond) ═══ -->

                <!-- Triangle (top) -->
                <Ellipse Canvas.Left="612" Canvas.Top="170" Width="34" Height="34" StrokeThickness="1.5">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource BtnOffBrush}"/>
                            <Setter Property="Stroke" Value="{StaticResource BtnTriangleBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TrianglePressed}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource BtnTriangleBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Canvas.Left="612" Canvas.Top="177" Width="34" TextAlignment="Center"
                           Text="△" FontSize="15" Foreground="{StaticResource TextPrimaryBrush}"/>

                <!-- Circle (right) -->
                <Ellipse Canvas.Left="648" Canvas.Top="206" Width="34" Height="34" StrokeThickness="1.5">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource BtnOffBrush}"/>
                            <Setter Property="Stroke" Value="{StaticResource BtnCircleBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CirclePressed}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource BtnCircleBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Canvas.Left="648" Canvas.Top="213" Width="34" TextAlignment="Center"
                           Text="○" FontSize="15" Foreground="{StaticResource TextPrimaryBrush}"/>

                <!-- Cross (bottom) -->
                <Ellipse Canvas.Left="612" Canvas.Top="242" Width="34" Height="34" StrokeThickness="1.5">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource BtnOffBrush}"/>
                            <Setter Property="Stroke" Value="{StaticResource BtnCrossBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CrossPressed}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource BtnCrossBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Canvas.Left="612" Canvas.Top="249" Width="34" TextAlignment="Center"
                           Text="✕" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>

                <!-- Square (left) -->
                <Ellipse Canvas.Left="576" Canvas.Top="206" Width="34" Height="34" StrokeThickness="1.5">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource BtnOffBrush}"/>
                            <Setter Property="Stroke" Value="{StaticResource BtnSquareBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SquarePressed}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource BtnSquareBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Canvas.Left="576" Canvas.Top="213" Width="34" TextAlignment="Center"
                           Text="□" FontSize="15" Foreground="{StaticResource TextPrimaryBrush}"/>

                <!-- ═══ Trigger percentages ═══ -->
                <TextBlock Canvas.Left="120" Canvas.Top="16" Width="40" TextAlignment="Center"
                           Text="{Binding L2Percent}" FontSize="9"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Canvas.Left="700" Canvas.Top="16" Width="40" TextAlignment="Center"
                           Text="{Binding R2Percent}" FontSize="9"
                           Foreground="{StaticResource TextSecondaryBrush}"/>

            </Canvas>
        </Viewbox>
    </Grid>
</UserControl>
