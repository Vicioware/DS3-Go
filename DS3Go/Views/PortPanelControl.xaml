<UserControl x:Class="DS3Go.Views.PortPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DS3Go.Converters">

    <UserControl.Resources>
        <converters:PortStateToBrushConverter x:Key="StateToBrush"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border CornerRadius="8" Padding="12,10"
            BorderThickness="1"
            BorderBrush="{Binding State, Converter={StaticResource StateToBrush}}">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{StaticResource CardBrush}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Port number + indicator -->
            <DockPanel Grid.Row="0" Margin="0,0,0,3">
                <Ellipse DockPanel.Dock="Right" Width="8" Height="8"
                         VerticalAlignment="Center" HorizontalAlignment="Right"
                         Fill="{Binding State, Converter={StaticResource StateToBrush}}"/>
                <TextBlock FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}">
                    <Run Text="P"/><Run Text="{Binding PortNumber, Mode=OneWay}"/>
                    <Run Text=" · " Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Run Text="{Binding StateDisplayName, Mode=OneWay}"
                         FontWeight="Normal" FontSize="11"
                         Foreground="{StaticResource TextSecondaryBrush}"/>
                </TextBlock>
            </DockPanel>

            <!-- Device name -->
            <TextBlock Grid.Row="1" FontSize="11.5" TextTrimming="CharacterEllipsis"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,1">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="{Binding DeviceName}"/>
                        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DeviceName}" Value="">
                                <Setter Property="Text" Value="Sin asignar"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="FontStyle" Value="Italic"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Device type -->
            <TextBlock Grid.Row="2" Text="{Binding DeviceType}"
                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                       Visibility="{Binding HasDevice, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </Border>
</UserControl>
