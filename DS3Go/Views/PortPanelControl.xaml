<UserControl x:Class="DS3Go.Views.PortPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DS3Go.Converters">

    <UserControl.Resources>
        <converters:PortStateToBrushConverter x:Key="StateToBrush"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border CornerRadius="10" Padding="14"
            BorderThickness="2"
            BorderBrush="{Binding State, Converter={StaticResource StateToBrush}}">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}">
                    <Run Text="Puerto "/><Run Text="{Binding PortNumber, Mode=OneWay}"/>
                </TextBlock>
                <Ellipse Width="10" Height="10" Margin="8,0,0,0"
                         VerticalAlignment="Center"
                         Fill="{Binding State, Converter={StaticResource StateToBrush}}"/>
            </StackPanel>

            <TextBlock Grid.Row="1" Text="{Binding StateDisplayName}"
                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,4"/>

            <TextBlock Grid.Row="2" FontSize="12" TextTrimming="CharacterEllipsis"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,2">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="{Binding DeviceName}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DeviceName}" Value="">
                                <Setter Property="Text" Value="—"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Grid.Row="3" Text="{Binding DeviceType}"
                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                       Visibility="{Binding HasDevice, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </Border>
</UserControl>
