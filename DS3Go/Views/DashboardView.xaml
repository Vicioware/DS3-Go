<UserControl x:Class="DS3Go.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DS3Go.Views"
             xmlns:vm="clr-namespace:DS3Go.ViewModels"
             xmlns:converters="clr-namespace:DS3Go.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <Border Grid.Row="0" Padding="20,12" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="DS3" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="{StaticResource AppFont}"/>
                    <TextBlock Text=" Go" FontSize="20" FontWeight="Light"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="{StaticResource AppFontLight}"/>
                    <TextBlock Text="  ·  Controller Manager" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="4,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Port Cards ═══ -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Ports}" Margin="16,14,16,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:PortViewModel}">
                    <views:PortPanelControl Margin="4" Cursor="Hand">
                        <views:PortPanelControl.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.SelectPortCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                          CommandParameter="{Binding}"/>
                        </views:PortPanelControl.InputBindings>
                    </views:PortPanelControl>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ═══ Selected Port Actions + Tabs ═══ -->
        <Grid Grid.Row="2" Margin="16,10,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Context toolbar for selected port -->
            <Border Grid.Row="0" Padding="10,6" CornerRadius="6,6,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,1,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="Puerto seleccionado: "/>
                        <Run Text="{Binding SelectedPort.PortNumber, Mode=OneWay, FallbackValue=-}"
                             FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Run Text="  "/>
                        <Run Text="{Binding SelectedPort.DeviceName, Mode=OneWay, FallbackValue=}"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                    </TextBlock>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Move Up -->
                        <Button Style="{StaticResource IconButton}" ToolTip="Mover arriba (intercambiar con puerto anterior)"
                                Content="▲" FontSize="10" Margin="0,0,2,0"
                                Command="{Binding MovePortUpCommand}"
                                CommandParameter="{Binding SelectedPort.PortNumber}"/>
                        <!-- Move Down -->
                        <Button Style="{StaticResource IconButton}" ToolTip="Mover abajo (intercambiar con puerto siguiente)"
                                Content="▼" FontSize="10" Margin="0,0,8,0"
                                Command="{Binding MovePortDownCommand}"
                                CommandParameter="{Binding SelectedPort.PortNumber}"/>
                        <!-- Forget -->
                        <Button Style="{StaticResource DangerButton}" Padding="10,4"
                                ToolTip="Olvidar este mando y liberar el puerto"
                                Content="Olvidar mando" FontSize="11"
                                Command="{Binding ForgetDeviceCommand}"
                                CommandParameter="{Binding SelectedPort.PortNumber}"
                                IsEnabled="{Binding SelectedPort.HasDevice}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Tabs -->
            <TabControl Grid.Row="1" Padding="0">
                <TabItem Header="INPUT TESTER">
                    <views:InputTesterView DataContext="{Binding InputTester}" Margin="0,4,0,0"/>
                </TabItem>
                <TabItem Header="REMAPEO">
                    <views:RemappingView DataContext="{Binding Remapping}" Margin="0,4,0,0"/>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- ═══ Status Bar ═══ -->
        <Border Grid.Row="3" Padding="16,5" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Ellipse Width="7" Height="7" Margin="0,0,6,0" Fill="{StaticResource PortConnectedBrush}"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="ViGEmBus: No disponible"/>
                            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsViGEmAvailable}" Value="True">
                                    <Setter Property="Text" Value="ViGEmBus: Activo"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
